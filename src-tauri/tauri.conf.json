{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mikro Cari Aktarim",
  "version": "0.1.6",
  "identifier": "com.hzkucuk.mikro.cariaktarim",
  "build": {
    "frontendDist": "../dist",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mikro Cari Kartı Aktarma — Trigger Yönetimli",
        "width": 1320,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "maximized": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "hzkucuk",
    "copyright": "© 2026",
    "shortDescription": "Mikro V17 Cari Kartı Aktarma",
    "longDescription": "Mikro V17 cari kartı aktarma modülü — aktarım öncesi/sonrası SIPARISLER trigger'ını otomatik yöneten bağımsız masaüstü uygulaması.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["turkish", "english"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2N0JFMzdENjIyNTM1RTMKUldUak5TVmlmZU43VnZTZFZQYjRsdFFOVUlNMEsrNFdQNW05dVlaYXBrR2RNQ2JuM2J2NXl0ODkK",
      "endpoints": [
        "https://github.com/hzkucuk/mikro-v17-cari-aktarim/releases/latest/download/latest.json"
      ]
    }
  }
}
